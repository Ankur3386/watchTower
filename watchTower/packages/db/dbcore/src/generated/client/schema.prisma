// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  username String
  password String
  email    String    @unique
  project  Project[]
}

model Project {
  id        String      @id @default(uuid())
  name      String
  apiKey    String      @unique @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  dashboard Dashboard[]
}

model Dashboard {
  id               String             @id @default(uuid())
  projectId        String
  project          Project            @relation(fields: [projectId], references: [id])
  dashBoard_widget DashboardWidgets[]
}

model DashboardWidgets {
  id          String    @id @default(uuid())
  chartType   chartType
  metric      metric
  dashBoardId String
  dashBoarsId Dashboard @relation(fields: [dashBoardId], references: [id])
}

enum metric {
  cpuUsage
  memoryUsage
  network
  reqperSec
  totalUser
  activeUser
  responseTime
  errorResponse
}

enum chartType {
  HISTOGRAM
  BAR_GRAPH
  Number
  Pie_Chart
}
