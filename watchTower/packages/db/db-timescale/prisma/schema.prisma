generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @default(uuid()) @id
  username String
  password String
  email String
  project Project[]
}
model Project{
  id String @default(uuid()) @id
  name String
  apiKey String @default(uuid()) @unique
  userId String
  user User @relation(fields: [userId],references: [id])
  dashboard Dashboard[]
}
 
model Dashboard{
  id String  @default(uuid()) @id
  projectId String
  project Project @relation(fields: [projectId],references: [id])
  dshBoard_widget DashboardWidgets[]
}
model DashboardWidgets{
   id String  @default(uuid()) @id
   chartType chartType
   metric  metric
   dashBoardId String
   dashBoarsId Dashboard @relation(fields:[dashBoardId],references: [id])

}
enum metric{
  cpuUsage
  memoryUsage
  network
  reqperSec
  totalUser
  activeUser
  responseTime
  errorResponse
}
enum chartType{
  HISTOGRAM
  BAR_GRAPH
  Number
  Pie_Chart

}